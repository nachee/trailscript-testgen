import { test, expect } from '@playwright/test';
{% if has_variables %}
import { testVariables } from './variables';
{% endif %}

/**
 * Flow: {{ flow_name | ts_block_comment }}
 * Pattern: {{ canonical_pattern | ts_block_comment }}
 * Popularity: {{ popularity_score }}% of sessions ({{ behavior_count }} behaviors)
 *
 * Generated by TrailScript
 */
test.describe({{ flow_name | ts_literal }}, () => {
{% if before_each_steps %}
  test.beforeEach(async ({ page }) => {
    // Navigate to {{ entry_url | ts_line_comment }} via most popular route
    await page.goto({{ (base_url ~ entry_url) | ts_literal }});
{% for step in before_each_steps %}

    // {{ step.description | ts_line_comment }}
{% if step.type == 'click' %}
    await page.{{ step.locator }}.click({{ step.options | default('') }});
{% elif step.type == 'navigation' %}
    await page.waitForURL({{ step.url | ts_literal }});
{% endif %}
{% if step.assertions %}
{% for assertion in step.assertions %}
    {{ assertion }};
{% endfor %}
{% endif %}
{% endfor %}
  });
{% else %}
  test.beforeEach(async ({ page }) => {
    await page.goto({{ (base_url ~ entry_url) | ts_literal }});
  });
{% endif %}
{% for behavior in behaviors %}

  test({{ behavior.test_name | ts_literal }}, async ({ page }) => {
{% for step in behavior.steps %}

    // Step {{ loop.index }}: {{ step.description | ts_line_comment }}
{% if step.repeat_count is defined and step.repeat_count > 1 %}
    for (let i = 0; i < {{ step.repeat_count }}; i++) {
{% if step.type == 'click' %}
      await page.{{ step.locator }}.click();
{% endif %}
    }
{% elif step.type == 'navigation' %}
    await page.waitForURL({{ step.url | ts_literal }});
{% elif step.type == 'click' %}
    await page.{{ step.locator }}.click({{ step.options | default('') }});
{% elif step.type == 'fill' %}
    await page.{{ step.locator }}.fill({{ step.value }});
{% elif step.type == 'check' %}
{% if step.checked %}
    await page.{{ step.locator }}.check();
{% else %}
    await page.{{ step.locator }}.uncheck();
{% endif %}
{% elif step.type == 'select_option' %}
    await page.{{ step.locator }}.selectOption({{ step.value }});
{% elif step.type == 'press_key' %}
    await page.{{ step.locator }}.press({{ step.key | ts_literal }});
{% elif step.type == 'drag_drop' %}
    await page.{{ step.source_locator }}.dragTo(page.{{ step.target_locator }});
{% elif step.type == 'file_upload' %}
    const [fileChooser] = await Promise.all([
      page.waitForEvent('filechooser'),
      page.{{ step.locator }}.click(),
    ]);
    await fileChooser.setFiles({{ step.files }});
{% elif step.type == 'dialog' %}
    page.on('dialog', async (dialog) => {
      await dialog.{{ step.action }}({{ step.input_value | default('') }});
    });
{% elif step.type == 'wait_for_response' %}
    await page.waitForResponse(resp => resp.url().includes({{ step.url_pattern | ts_literal }}));
{% endif %}
{% if step.assertions %}
{% for assertion in step.assertions %}
    {{ assertion }};
{% endfor %}
{% endif %}
{% endfor %}
  });
{% endfor %}
});
